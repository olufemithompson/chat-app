# Copy to .env.local and fill in real values (never commit .env.local)

# ─── Database (Prisma) ─────────────────────────────────────────────────────────
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/chatapp"

# ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────
# NextAuth accepts AUTH_* or NEXTAUTH_* — set at least one secret + URL.
# Generate secret: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_SECRET=
AUTH_URL=
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Public (exposed to the browser) ───────────────────────────────────────────
# Must match where users open the app (Socket.io client + CORS)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Custom server (optional) ─────────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=3000
